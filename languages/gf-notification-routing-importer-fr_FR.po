#. Plugin Name of the plugin
msgid "Notification Routing Importer for Gravity Forms"
msgstr "Importateur de routage de notifications pour Gravity Forms"

#. Description of the plugin
msgid "Bulk import notification routing rules from CSV/XLSX files into Gravity Forms' \"Configure Routing\" feature."
msgstr "Importation en masse des règles de routage de notifications depuis des fichiers CSV/XLSX dans la fonctionnalité « Configurer le routage » de Gravity Forms."

#: includes/class-import-handler.php
msgid "Importing…"
msgstr "Importation…"

#: includes/class-import-handler.php
msgid "%d routing rule(s) imported successfully."
msgstr "%d règle(s) de routage importée(s) avec succès."

#: includes/class-import-handler.php
msgid "Import failed: %s"
msgstr "Échec de l'importation : %s"

#: includes/class-import-handler.php
msgid "Please select a CSV or XLSX file."
msgstr "Veuillez sélectionner un fichier CSV ou XLSX."

#: includes/class-import-handler.php
msgid "Append to existing"
msgstr "Ajouter aux existantes"

#: includes/class-import-handler.php
msgid "Import Routing Rules"
msgstr "Importer des règles de routage"

#: includes/class-import-handler.php
msgid "Warnings:"
msgstr "Avertissements :"

