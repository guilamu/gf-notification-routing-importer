msgid "Drop your file here or"
msgstr "Déposez votre fichier ici ou"

#: includes/class-import-handler.php
msgid "Select a file"
msgstr "Sélectionner un fichier"

#: includes/class-import-handler.php
msgid "Download a sample file:"
msgstr "Télécharger un fichier exemple :"

#: includes/class-import-handler.php
msgid "Export Routing Rules"
msgstr "Exporter les règles de routage"

#: includes/class-import-handler.php
msgid "Permission denied."
msgstr "Autorisation refusée."

#: includes/class-import-handler.php
msgid "Security check failed."
msgstr "Vérification de sécurité échouée."

#: includes/class-import-handler.php
msgid "No file uploaded or upload error."
msgstr "Aucun fichier téléversé ou erreur de téléversement."

#: includes/class-import-handler.php
msgid "Only CSV and XLSX files are allowed."
msgstr "Seuls les fichiers CSV et XLSX sont autorisés."

#: includes/class-import-handler.php
msgid "Invalid form ID."
msgstr "Identifiant de formulaire invalide."

#: includes/class-import-handler.php
msgid "Form not found."
msgstr "Formulaire introuvable."

#: includes/class-import-handler.php
msgid "Invalid XLSX file."
msgstr "Fichier XLSX invalide."

#: includes/class-import-handler.php
msgid "File must have a header row and at least one data row."
msgstr "Le fichier doit contenir une ligne d'en-tête et au moins une ligne de données."

#: includes/class-import-handler.php
#, php-format
msgid "Row %1$d: invalid email \"%2$s\", skipped."
msgstr "Ligne %1$d : e-mail invalide « %2$s », ignorée."

#: includes/class-import-handler.php
#, php-format
msgid "Row %1$d: %2$s, skipped."
msgstr "Ligne %1$d : %2$s, ignorée."

#: includes/class-import-handler.php
#, php-format
msgid "Row %1$d: invalid operator \"%2$s\", skipped."
msgstr "Ligne %1$d : opérateur invalide « %2$s », ignorée."

#: includes/class-import-handler.php
msgid "No valid routing rules found in the file."
msgstr "Aucune règle de routage valide trouvée dans le fichier."

#: includes/class-import-handler.php
msgid "Failed to open CSV file."
msgstr "Impossible d'ouvrir le fichier CSV."

#: includes/class-import-handler.php
msgid "CSV file is empty."
msgstr "Le fichier CSV est vide."

#: includes/class-import-handler.php
#, php-format
msgid "Missing required column(s): %s. Expected headers: email, fieldId (or field), operator, value."
msgstr "Colonne(s) requise(s) manquante(s) : %s. En-têtes attendus : email, fieldId (ou field), operator, value."

#: includes/class-import-handler.php
msgid "empty field ID"
msgstr "identifiant de champ vide"

#: includes/class-import-handler.php
#, php-format
msgid "field ID %s not found in form"
msgstr "identifiant de champ %s introuvable dans le formulaire"

#: includes/class-import-handler.php
#, php-format
msgid "no field matching label \"%s\""
msgstr "aucun champ correspondant au libellé « %s »"

#: includes/class-import-handler.php
#, php-format
msgid "field ID %1$s is a %2$s field (not routable)"
msgstr "le champ ID %1$s est un champ %2$s (non routable)"

#: includes/class-xlsx-parser.php
msgid "PHP ZipArchive extension is required for XLSX support."
msgstr "L'extension PHP ZipArchive est requise pour le support XLSX."

#: includes/class-xlsx-parser.php
msgid "XLSX file not found."
msgstr "Fichier XLSX introuvable."

#: includes/class-xlsx-parser.php
msgid "Failed to open XLSX file."
msgstr "Impossible d'ouvrir le fichier XLSX."

#: includes/class-xlsx-parser.php
msgid "No worksheet found in XLSX file."
msgstr "Aucune feuille de calcul trouvée dans le fichier XLSX."

#: includes/class-xlsx-parser.php
msgid "Failed to parse worksheet XML."
msgstr "Impossible d'analyser le XML de la feuille de calcul."

#: includes/class-github-updater.php
msgid "Unable to rename the update folder. Please retry or update manually."
msgstr "Impossible de renommer le dossier de mise à jour. Veuillez réessayer ou mettre à jour manuellement."

